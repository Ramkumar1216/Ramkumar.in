# Django Settings
ENVIRONMENT=development
DEBUG=True
SECRET_KEY=your-secret-key-change-this-in-production-use-django-secret-key-generator
ALLOWED_HOSTS=localhost,127.0.0.1,yourdomain.com,www.yourdomain.com

# Database Configuration
# For Development (SQLite):
DB_ENGINE=django.db.backends.sqlite3
DB_NAME=db.sqlite3

# For Production (PostgreSQL):
# DB_ENGINE=django.db.backends.postgresql
# DB_NAME=portfolio_db
# DB_USER=postgres
# DB_PASSWORD=secure-password-here
# DB_HOST=localhost
# DB_PORT=5432

# Email Configuration (For Contact Form)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password

# Site Settings
SITE_NAME=Ramkumar Portfolio
SITE_URL=http://localhost:8000

# WhatsApp Business (for contact forms)
WHATSAPP_NUMBER=919876543210

# Admin Email (for contact form notifications)
ADMIN_EMAIL=ramkumar@example.com
